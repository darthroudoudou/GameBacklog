@page "/gamelist"
@rendermode InteractiveServer

@using BlazorApp1.server
@using BlazorApp1.server.DbEntity

@inject GameService gameService

<h1>Game Backlog</h1>
<br />
<h2>Ajouter un jeu</h2>
<table class="table param-table">
    <tr>
        <td> 
            <input @bind="newGameTitle" placeholder="Titre" />
        </td>
	    <td>
            <label>Plateforme :</label>
            <select @bind="newGamePlatform">
                @foreach (var platform in Enum.GetValues(typeof(Platform)))
                {
                    <option value="@platform">@platform</option>
                }
            </select>
        </td>
        <td>
            <button class="btn btn-primary" @onclick="AddGame">Ajouter</button>
        </td>
    </tr>
</table>
<br />
<h2>Filtres</h2>
<table class="table param-table">
	<tr>
		<td> 
			<label>Plateforme :</label>
			<select @bind="platformFilter" @bind:after="LoadGames">
				<option value="">ALL</option>
				@foreach (var platform in Enum.GetValues(typeof(Platform)))
				{
					<option value="@platform">@platform</option>
				}
			</select>
		</td>
		<td>
			To do : <input type="checkbox" @bind="isTodoFilter" @bind:after="LoadGames" />
		</td>
		<td>
			Retro : <input type="checkbox" @bind="isRetroFilter" @bind:after="LoadGames" />
		</td>
	</tr>
</table>
<table class="table table-striped ">
    <thead>
        <tr>
            <th><button class="btn btn-link p-0" @onclick="() => ToggleSort(nameof(Game.Order))">Order @SortIndicator(nameof(Game.Order))</button></th>
            <th><button class="btn btn-link p-0" @onclick="() => ToggleSort(nameof(Game.Title))">Titre @SortIndicator(nameof(Game.Title))</button></th>
            <th><button class="btn btn-link p-0" @onclick="() => ToggleSort(nameof(Game.Platform))">Plateforme @SortIndicator(nameof(Game.Platform))</button></th>
            <th><button class="btn btn-link p-0" @onclick="() => ToggleSort(nameof(Game.IsRetro))">Retro @SortIndicator(nameof(Game.IsRetro))</button></th>
            <th><button class="btn btn-link p-0" @onclick="() => ToggleSort(nameof(Game.IsCompleted))">Completed @SortIndicator(nameof(Game.IsCompleted))</button></th>
            <th><button class="btn btn-link p-0" @onclick="() => ToggleSort(nameof(Game.IsTodo))">To do @SortIndicator(nameof(Game.IsTodo))</button></th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in gameList)
        {
            <tr>
                <td><input @bind="@item.Order" @bind:after="@(() => this.UpdateGame(item))" /></td>
                <td>@item.Title</td>
                <td>@item.Platform</td>
                <td>
                    <input name="Retro" type="checkbox" @bind="item.IsRetro" @bind:after="@(() => this.UpdateGame(item))" />
                </td>
                <td>
                    <input name="Completed" type="checkbox" @bind="item.IsCompleted" @bind:after="@(() => this.UpdateGame(item))" />
                </td>
                <td>
                    <input name="To do" type="checkbox" @bind="item.IsTodo" @bind:after="@(() => this.UpdateGame(item))" />
                </td>
                <td>
                    <button class="btn btn-danger btn-sm" @onclick="@(() => this.DeleteGame(item.Id))">Supprimer</button>
                </td>
            </tr>
        }
    </tbody>
</table>


@code {

    private List<Game> gameList = new();

    private string? sortBy;
    private bool sortDesc;

    private string newGameTitle = string.Empty;
    private Platform? newGamePlatform = Platform.PC;

    private Platform? platformFilter;
    private bool isTodoFilter;
    private bool? isRetroFilter;

    private Platform? PlatformFilter
    {
        get => platformFilter;
        set
        {
            platformFilter = value == null || value.ToString() == "" ? null : value;
        }
    }

    protected override void OnInitialized()
    {
        this.LoadGames();
    }

    private void LoadGames()
    {
        gameList = gameService.RetrieveGames(isTodo: isTodoFilter, platform: this.PlatformFilter, sortBy: sortBy, isDescending: sortDesc, isRetro: isRetroFilter);
    }

    private void ToggleSort(string column)
    {
        if (sortBy == column)
        {
            sortDesc = !sortDesc;
        }
        else
        {
            sortBy = column;
            sortDesc = false;
        }

        LoadGames();
    }

    private MarkupString SortIndicator(string column)
    {
        if (sortBy != column) return (MarkupString)string.Empty;
        return sortDesc ? (MarkupString)" \u25BC" : (MarkupString)" \u25B2";
    }

    private void AddGame()
    {
        if (newGamePlatform != null)
        {
            this.gameService.AddGame(new Game { Id = gameService.GetNextId(), Title = newGameTitle, Platform = newGamePlatform.Value });
            newGameTitle = string.Empty;
            this.LoadGames();
        }
    }

    private void UpdateGame(Game game)
    {
        this.gameService.UpdateGame(game);
        this.LoadGames();
    }

    private void DeleteGame(int gameId)
    {
        this.gameService.DeleteGame(gameId);
        this.LoadGames();
    }
}
