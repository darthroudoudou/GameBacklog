@page "/gamelist"
@rendermode InteractiveServer

@using BlazorApp1.server
@using BlazorApp1.server.DbEntity

@inject GameService gameService

<h1>Game List</h1>

<input @bind="newGameTitle" placeholder="Nouveau jeu" />
<div>
    <label>Plateforme :</label>
    <select @bind="newGamePlatform">
        @foreach (var platform in Enum.GetValues(typeof(Platform)))
        {
            <option value="@platform">@platform</option>
        }
    </select>
</div>
<button class="btn btn-primary" @onclick="AddGame">Ajouter</button>

<ul>
    @foreach (var item in gameList)
    {
        <li>
            @item.Title
            @item.Platform
            <input name="Completed" type="checkbox" @bind="item.IsCompleted" @onclick="@(() => this.UpdateGame(item))" /> Completed
            <input name="To do" type="checkbox" @bind="item.IsTodo" @onclick="@(() => this.UpdateGame(item))" /> To do
            <button class="btn btn-primary" @onclick="@(() => this.DeleteGame(item.Id))">Supprimer</button>
        </li>
    }
</ul>


@code {

    private List<Game> gameList = new();
    private string newGameTitle = string.Empty;

    private Platform? newGamePlatform = null;
    protected override void OnInitialized()
    {
        this.LoadGames();
    }

    private void LoadGames()
    {
        gameList = gameService.GetAllGames();
    }

    private void AddGame()
    {
        if (newGamePlatform != null)
        {
            this.gameService.AddGame(new Game { Id = gameService.GetNextId(), Title = newGameTitle, Platform = newGamePlatform.Value });
            newGameTitle = string.Empty;
            this.LoadGames();
        }
    }

    private void UpdateGame(Game game)
    {
        this.gameService.UpdateGame(game);
        this.LoadGames();
    }

    private void DeleteGame(int gameId)
    {
        this.gameService.DeleteGame(gameId);
        this.LoadGames();
    }
}
